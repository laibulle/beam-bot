defmodule BeamBotWeb.UserResetPasswordControllerTest do
  use BeamBotWeb.ConnCase, async: true

  import BeamBot.AccountsFixtures
  import Mox

  alias BeamBot.Accounts
  alias BeamBot.Exchanges.Infrastructure.Adapters.Ecto.TradingPairsRepositoryMock

  setup :verify_on_exit!

  setup do
    expect(TradingPairsRepositoryMock, :list_trading_pairs, fn -> [] end)
    %{user: user_fixture()}
  end

  describe "POST /users/reset_password" do
    test "creates a new user session", %{conn: conn, user: user} do
      conn =
        conn
        |> fetch_session()
        |> post(~p"/users/reset_password", %{
          "user" => %{
            "password" => "new valid password",
            "reset_password_token" => user_reset_password_token_fixture(user)
          }
        })

      assert get_session(conn, :user_token)
      assert redirected_to(conn) == ~p"/users/settings"
    end

    test "does not log in the user if reset password token is invalid", %{conn: conn} do
      conn =
        conn
        |> fetch_session()
        |> post(~p"/users/reset_password", %{
          "user" => %{
            "password" => "new valid password",
            "reset_password_token" => "oops"
          }
        })

      session = get_session(conn)
      refute get_session(conn, :user_token)
      assert session["flash"]["error"] =~ "Reset password link is invalid or it has expired"
      assert redirected_to(conn) == ~p"/users/reset_password"
    end

    test "does not log in the user if password is invalid", %{conn: conn, user: user} do
      conn =
        conn
        |> fetch_session()
        |> post(~p"/users/reset_password", %{
          "user" => %{
            "password" => "not valid",
            "reset_password_token" => user_reset_password_token_fixture(user)
          }
        })

      refute get_session(conn, :user_token)
      assert get_session(conn)["flash"]["error"] =~ "should be at least 8 character"
      assert redirected_to(conn) == ~p"/users/reset_password"
    end
  end
end
