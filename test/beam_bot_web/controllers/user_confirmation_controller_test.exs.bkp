defmodule BeamBotWeb.UserConfirmationControllerTest do
  use BeamBotWeb.ConnCase, async: true

  import BeamBot.AccountsFixtures
  import Mox

  alias BeamBot.Accounts
  alias BeamBot.Exchanges.Infrastructure.Adapters.Ecto.TradingPairsRepositoryMock

  setup :verify_on_exit!

  setup do
    expect(TradingPairsRepositoryMock, :list_trading_pairs, fn -> [] end)
    %{user: user_fixture()}
  end

  describe "POST /users/confirm/:token" do
    test "confirms the given token once", %{conn: conn, user: user} do
      token =
        extract_user_token(fn url ->
          Accounts.deliver_user_confirmation_instructions(user, url)
        end)

      conn = post(conn, ~p"/users/confirm/#{token}")
      assert redirected_to(conn) == ~p"/dashboard"

      assert Accounts.get_user!(user.id).confirmed_at
      refute get_session(conn, :user_token)
      assert Phoenix.Flash.get(conn.assigns.flash, :info) =~ "Account confirmed successfully"
    end

    test "does not confirm email with invalid token", %{conn: conn, user: user} do
      conn = post(conn, ~p"/users/confirm/oops")
      assert redirected_to(conn) == ~p"/dashboard"

      refute Accounts.get_user!(user.id).confirmed_at
      refute get_session(conn, :user_token)
      assert Phoenix.Flash.get(conn.assigns.flash, :error) =~ "Invalid confirmation link"
    end

    test "does not confirm email if user is already confirmed", %{conn: conn, user: user} do
      token =
        extract_user_token(fn url ->
          Accounts.deliver_user_confirmation_instructions(user, url)
        end)

      Accounts.confirm_user!(user)
      conn = post(conn, ~p"/users/confirm/#{token}")
      assert redirected_to(conn) == ~p"/dashboard"

      assert Accounts.get_user!(user.id).confirmed_at
      refute get_session(conn, :user_token)
      assert Phoenix.Flash.get(conn.assigns.flash, :error) =~ "Account already confirmed"
    end
  end
end
